# نسخ للتطوير المحلي: cp .env.example .env

NODE_ENV=development
JWT_SECRET=change-me-in-production-use-long-random-string
PORT=4000

PUBLIC_BASE_URL=http://localhost:4000
APP_NAME=GOSTAAP

DELIVERY_RATE_PER_KM=2.5
DELIVERY_MIN_FEE=5

# عمولة المنصة % (قابلة للتعديل من لوحة الإدارة — هذه قيم افتراضية)
RESTAURANT_COMMISSION_PCT=12
CAPTAIN_COMMISSION_PCT=8
UPLOAD_DIR=./uploads
# اختياري — افتراضياً: backend/data/app.db و ./uploads
# مع قرص دائم على Render (Starter+): DATABASE_PATH=/var/data/app.db و UPLOAD_DIR=/var/data/uploads

# ─── مدير المنصة (POST /api/auth/login ثم /api/admin/*) ───
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── SendGrid ───
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=no-reply@yourdomain.com

ALLOW_DEV_OTP_LOG=false
OTP_EXPIRY_MINUTES=15
OTP_RESEND_COOLDOWN_SEC=60
OTP_MAX_ATTEMPTS=5
