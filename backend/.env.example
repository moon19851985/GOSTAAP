JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=4000
DELIVERY_RATE_PER_KM=2.5
DELIVERY_MIN_FEE=5
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:4000
APP_NAME=قسطاس

# ─── SendGrid (مُفضّل) ───
# أنشئ API Key: https://app.sendgrid.com/settings/api_keys
# وثّق المرسل: Settings → Sender Authentication
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=no-reply@yourdomain.com

# ─── أو SMTP عام (بديل) ───
# SendGrid SMTP: host=smtp.sendgrid.net user=apikey pass=نفس_API_Key
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx

ALLOW_DEV_OTP_LOG=false
OTP_EXPIRY_MINUTES=15
OTP_RESEND_COOLDOWN_SEC=60
OTP_MAX_ATTEMPTS=5
